model User {
    id          String @id @default(uuid())
    name        String
    email       String

    ads         Ad[]

    createAt    Datatime @default(now())
}

model Ad {
    id              String @id @default(uuid())
    
    title           String
    description     String

    category        String

    price           Float?

    isDonation      Boolean

    imageUrl        String?

    userId          String

    user            User @relation(fields:[userId],references:[id])

    createAt        Datatime @default(now())
}