generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  ads Ads[]
}

model Ads {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  price       Float?
  isDonation  Boolean
  imageUrl    String?
  createdAt   DateTime @default(now())

  userId String
  user   Users  @relation(fields: [userId], references: [id])
}
